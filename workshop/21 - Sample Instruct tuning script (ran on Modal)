{"cells":[{"cell_type":"markdown","metadata":{"id":"PxAPxORGfwtG"},"source":["# GPT-2 (124M) Instruct Fine-Tuning with LoRA"],"id":"PxAPxORGfwtG"},{"cell_type":"code","metadata":{"scrolled":true,"id":"HSBZ7nW3fwtH","outputId":"390bcb79-30a4-48b4-9c02-2ccb2331a9f5"},"source":["uv pip install --system -q torchao torchtune tiktoken datasets matplotlib peft"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Note: you may need to restart the kernel to use updated packages.\n"]}],"id":"HSBZ7nW3fwtH"},{"cell_type":"markdown","metadata":{"id":"1NDgl1DbfwtH"},"source":["## Imports"],"id":"1NDgl1DbfwtH"},{"cell_type":"code","metadata":{"scrolled":true,"id":"Ow-vvgLcfwtH","outputId":"50503ba9-0667-4da3-9422-3d780e4e38f6"},"source":["import os, math, time, json, random\n","import tiktoken\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","from dataclasses import dataclass\n","from datasets import load_dataset\n","import matplotlib.pyplot as plt\n","from IPython.display import clear_output\n","\n","from torchtune.modules import (\n","    RMSNorm, RotaryPositionalEmbeddings, MultiHeadAttention,\n","    TransformerSelfAttentionLayer, TransformerDecoder, TiedLinear,\n",")\n","from peft import get_peft_model, LoraConfig\n","\n","print(f\"PyTorch: {torch.__version__}\")\n","if torch.cuda.is_available():\n","    print(f\"GPU: {torch.cuda.get_device_name()}\")\n","    print(f\"Memory: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["Skipping import of cpp extensions due to incompatible torch version. Please upgrade to torch >= 2.11.0 (found 2.8.0+cu129).\n","/usr/local/lib/python3.12/site-packages/torchao/quantization/quant_api.py:1731: SyntaxWarning: invalid escape sequence '\\.'\n","  \"\"\"Configuration class for applying different quantization configs to modules or parameters based on their fully qualified names (FQNs).\n"]},{"output_type":"stream","name":"stdout","text":["PyTorch: 2.8.0+cu129\n","GPU: NVIDIA A100-SXM4-80GB\n","Memory: 85.1 GB\n"]}],"id":"Ow-vvgLcfwtH"},{"cell_type":"markdown","metadata":{"id":"eWxjkuKwfwtI"},"source":["## Storage"],"id":"eWxjkuKwfwtI"},{"cell_type":"code","metadata":{"scrolled":true,"id":"dq32CzDufwtI","outputId":"48a740f0-e131-4a9a-d300-26a9141cbec1"},"source":["STORAGE_ROOT = None\n","\n","try:\n","    from google.colab import drive\n","    drive.mount('/content/drive')\n","    STORAGE_ROOT = \"/content/drive/MyDrive/gpt2_workshop\"\n","    print(\"Using Google Drive for storage.\")\n","except (ImportError, ModuleNotFoundError):\n","    pass\n","\n","if STORAGE_ROOT is None:\n","    for candidate in [\"/mnt/gpt2-workshop\"]:\n","        if os.path.isdir(candidate):\n","            STORAGE_ROOT = candidate\n","            print(f\"Using Modal Volume at {candidate}\")\n","            break\n","\n","if STORAGE_ROOT is None:\n","    STORAGE_ROOT = \"/tmp/gpt2_workshop\"\n","    print(f\"FALLBACK: Using ephemeral {STORAGE_ROOT}\")\n","    print(\"WARNING: Data will be lost when kernel stops!\")\n","\n","CHECKPOINT_DIRECTORY = os.path.join(STORAGE_ROOT, \"checkpoints\")\n","LOG_DIRECTORY = os.path.join(STORAGE_ROOT, \"logs\")\n","os.makedirs(CHECKPOINT_DIRECTORY, exist_ok=True)\n","os.makedirs(LOG_DIRECTORY, exist_ok=True)\n","\n","PRETRAINED_CHECKPOINT_PATH = os.path.join(CHECKPOINT_DIRECTORY, \"workshop-v1-pretraining.pth\")\n","INSTRUCT_CHECKPOINT_PATH = os.path.join(CHECKPOINT_DIRECTORY, \"workshop-v1-instruct-tuned.pth\")\n","\n","assert os.path.exists(PRETRAINED_CHECKPOINT_PATH), (\n","    f\"Pretrained checkpoint not found at {PRETRAINED_CHECKPOINT_PATH}\\n\"\n","    f\"Run the pretraining notebook first.\"\n",")\n","print(f\"Input:  {PRETRAINED_CHECKPOINT_PATH}\")\n","print(f\"Output: {INSTRUCT_CHECKPOINT_PATH}\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Using Modal Volume at /mnt/gpt2-workshop\n","Input:  /mnt/gpt2-workshop/checkpoints/workshop-v1-pretraining.pth\n","Output: /mnt/gpt2-workshop/checkpoints/workshop-v1-instruct-tuned.pth\n"]}],"id":"dq32CzDufwtI"},{"cell_type":"markdown","metadata":{"id":"RFXThIPJfwtI"},"source":["## Configuration"],"id":"RFXThIPJfwtI"},{"cell_type":"code","metadata":{"scrolled":true,"id":"X83gs8I2fwtI","outputId":"692be301-7663-4771-9993-1c259edda18a"},"source":["@dataclass\n","class ModelArchitectureConfig:\n","    num_layers:       int   = 12\n","    num_heads:        int   = 12\n","    embedding_dim:    int   = 768\n","    vocabulary_size:  int   = 50304\n","    max_sequence_len: int   = 1024\n","    feedforward_dim:  int   = 3072\n","    rope_base_freq:   float = 10000.0\n","\n","\n","@dataclass\n","class LoraAdapterConfig:\n","    rank:           int   = 16\n","    alpha:          int   = 32\n","    dropout:        float = 0.05\n","    target_modules: tuple = (\"q_proj\", \"k_proj\", \"v_proj\",\n","                             \"output_proj\", \"fc_in\", \"fc_out\")\n","\n","\n","@dataclass\n","class TrainingRunConfig:\n","    dataset_name:            str   = \"tatsu-lab/alpaca\"\n","    validation_fraction:     float = 0.05\n","    max_tokens_per_example:  int   = 512\n","    batch_size:              int   = 32\n","    learning_rate:           float = 2e-4\n","    num_epochs:              int   = 6\n","    max_training_steps:      int   = 2500\n","    eval_frequency_fraction: float = 0.10\n","    copa_eval_sample_size:   int   = 500\n","\n","\n","ARCH = ModelArchitectureConfig()\n","LORA = LoraAdapterConfig()\n","TRAIN = TrainingRunConfig()\n","\n","print(f\"LoRA rank={LORA.rank}, alpha={LORA.alpha}, targets={LORA.target_modules}\")\n","print(f\"Training: {TRAIN.num_epochs} epochs, batch={TRAIN.batch_size}, lr={TRAIN.learning_rate}\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["LoRA rank=16, alpha=32, targets=('q_proj', 'k_proj', 'v_proj', 'output_proj', 'fc_in', 'fc_out')\n","Training: 6 epochs, batch=32, lr=0.0002\n"]}],"id":"X83gs8I2fwtI"},{"cell_type":"markdown","metadata":{"id":"QWfjvzkkfwtI"},"source":["## Model Architecture"],"id":"QWfjvzkkfwtI"},{"cell_type":"code","metadata":{"scrolled":true,"id":"KmFaawKBfwtI"},"source":["class ReluSquaredFeedForward(nn.Module):\n","    def __init__(self, input_dim, hidden_dim):\n","        super().__init__()\n","        self.fc_in = nn.Linear(input_dim, hidden_dim, bias=False)\n","        self.fc_out = nn.Linear(hidden_dim, input_dim, bias=False)\n","\n","    def forward(self, x):\n","        return self.fc_out(F.relu(self.fc_in(x)).square())\n","\n","\n","def build_transformer_decoder(arch=ARCH):\n","    head_dim = arch.embedding_dim // arch.num_heads\n","\n","    rotary_embeddings = RotaryPositionalEmbeddings(\n","        dim=head_dim, max_seq_len=arch.max_sequence_len, base=arch.rope_base_freq,\n","    )\n","\n","    self_attention = MultiHeadAttention(\n","        embed_dim=arch.embedding_dim, num_heads=arch.num_heads,\n","        num_kv_heads=arch.num_heads, head_dim=head_dim,\n","        q_proj=nn.Linear(arch.embedding_dim, arch.embedding_dim, bias=False),\n","        k_proj=nn.Linear(arch.embedding_dim, arch.embedding_dim, bias=False),\n","        v_proj=nn.Linear(arch.embedding_dim, arch.embedding_dim, bias=False),\n","        output_proj=nn.Linear(arch.embedding_dim, arch.embedding_dim, bias=False),\n","        pos_embeddings=rotary_embeddings, max_seq_len=arch.max_sequence_len,\n","        attn_dropout=0.0,\n","    )\n","\n","    feedforward = ReluSquaredFeedForward(arch.embedding_dim, arch.feedforward_dim)\n","\n","    transformer_layer = TransformerSelfAttentionLayer(\n","        attn=self_attention, mlp=feedforward,\n","        sa_norm=RMSNorm(arch.embedding_dim),\n","        mlp_norm=RMSNorm(arch.embedding_dim),\n","    )\n","\n","    token_embeddings = nn.Embedding(arch.vocabulary_size, arch.embedding_dim)\n","\n","    return TransformerDecoder(\n","        tok_embeddings=token_embeddings, layers=transformer_layer,\n","        num_layers=arch.num_layers, max_seq_len=arch.max_sequence_len,\n","        num_heads=arch.num_heads, head_dim=head_dim,\n","        norm=RMSNorm(arch.embedding_dim),\n","        output=TiedLinear(token_embeddings),\n","    )"],"execution_count":null,"outputs":[],"id":"KmFaawKBfwtI"},{"cell_type":"markdown","metadata":{"id":"whv0R5pVfwtI"},"source":["## Load Pretrained Model"],"id":"whv0R5pVfwtI"},{"cell_type":"code","metadata":{"scrolled":true,"id":"HCO-Y5zdfwtI","outputId":"30ba6bcf-3975-4016-832d-6a4e43ed6d6f"},"source":["model = build_transformer_decoder(ARCH)\n","pretrained_state = torch.load(PRETRAINED_CHECKPOINT_PATH, map_location=\"cpu\", weights_only=False)\n","model.load_state_dict(pretrained_state[\"model\"])\n","model = model.cuda()\n","print(f\"Loaded pretrained weights from {PRETRAINED_CHECKPOINT_PATH}\")\n","print(f\"Base parameters: {sum(p.numel() for p in model.parameters()):,}\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded pretrained weights from /mnt/gpt2-workshop/checkpoints/workshop-v1-pretraining.pth\n","Base parameters: 123,587,328\n"]}],"id":"HCO-Y5zdfwtI"},{"cell_type":"markdown","metadata":{"id":"ON49UAC1fwtI"},"source":["## Apply LoRA"],"id":"ON49UAC1fwtI"},{"cell_type":"code","metadata":{"scrolled":true,"id":"pLp_yQzNfwtI","outputId":"35568290-d949-4055-be15-324df58a378b"},"source":["lora_peft_config = LoraConfig(\n","    r=LORA.rank,\n","    lora_alpha=LORA.alpha,\n","    lora_dropout=LORA.dropout,\n","    target_modules=list(LORA.target_modules),\n","    bias=\"none\",\n",")\n","\n","model = get_peft_model(model, lora_peft_config)\n","model.print_trainable_parameters()"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["trainable params: 2,654,208 || all params: 126,241,536 || trainable%: 2.1025\n"]}],"id":"pLp_yQzNfwtI"},{"cell_type":"markdown","metadata":{"id":"U8nxd85efwtJ"},"source":["## Alpaca Dataset"],"id":"U8nxd85efwtJ"},{"cell_type":"code","metadata":{"scrolled":true,"colab":{"referenced_widgets":["1edce20764c345bf9e97afda3bbf06d9","a5917705d54a4f12bf4570303db2a371","9b4ee822f1be4650b6b8b2fed78f2ff7"]},"id":"lNqMO9KTfwtJ","outputId":"424c1671-0ecc-450c-dc42-3e0ae60e5769"},"source":["TOKENIZER = tiktoken.get_encoding(\"gpt2\")\n","END_OF_TEXT_TOKEN = TOKENIZER.eot_token\n","\n","\n","def format_as_alpaca_prompt(example):\n","    instruction = example[\"instruction\"]\n","    input_text = example.get(\"input\", \"\").strip()\n","    output_text = example[\"output\"]\n","\n","    if input_text:\n","        return (f\"### Instruction:\\n{instruction}\\n\\n\"\n","                f\"### Input:\\n{input_text}\\n\\n\"\n","                f\"### Response:\\n{output_text}\")\n","\n","    return (f\"### Instruction:\\n{instruction}\\n\\n\"\n","            f\"### Response:\\n{output_text}\")\n","\n","\n","def tokenize_alpaca_example(example):\n","    formatted_text = format_as_alpaca_prompt(example) + TOKENIZER.decode([END_OF_TEXT_TOKEN])\n","    token_ids = TOKENIZER.encode(formatted_text, allowed_special={\"<|endoftext|>\"})\n","    return token_ids[:TRAIN.max_tokens_per_example]\n","\n","\n","alpaca_dataset = load_dataset(TRAIN.dataset_name, split=\"train\")\n","print(f\"Alpaca: {len(alpaca_dataset)} examples\")\n","\n","train_val_split = alpaca_dataset.train_test_split(test_size=TRAIN.validation_fraction, seed=42)\n","training_examples = train_val_split[\"train\"]\n","validation_examples = train_val_split[\"test\"]\n","print(f\"Train: {len(training_examples)} | Val: {len(validation_examples)}\")\n","\n","training_token_sequences = [tokenize_alpaca_example(ex) for ex in training_examples]\n","validation_token_sequences = [tokenize_alpaca_example(ex) for ex in validation_examples]\n","average_sequence_length = sum(len(t) for t in training_token_sequences) / len(training_token_sequences)\n","print(f\"Avg token length: {average_sequence_length:.0f}\")"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"1edce20764c345bf9e97afda3bbf06d9","version_minor":0,"version_major":2},"text/plain":"README.md: 0.00B [00:00, ?B/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"a5917705d54a4f12bf4570303db2a371","version_minor":0,"version_major":2},"text/plain":"data/train-00000-of-00001-a09b74b3ef9c3b(…):   0%|          | 0.00/24.2M [00:00<?, ?B/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"9b4ee822f1be4650b6b8b2fed78f2ff7","version_minor":0,"version_major":2},"text/plain":"Generating train split:   0%|          | 0/52002 [00:00<?, ? examples/s]"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Alpaca: 52002 examples\n","Train: 49401 | Val: 2601\n","Avg token length: 89\n"]}],"id":"lNqMO9KTfwtJ"},{"cell_type":"markdown","metadata":{"id":"H_9fCQYPfwtJ"},"source":["## Batching"],"id":"H_9fCQYPfwtJ"},{"cell_type":"code","metadata":{"scrolled":true,"id":"UpfcTKCRfwtJ","outputId":"418ce20b-fbbd-4687-ea33-22c0a676f137"},"source":["def yield_padded_training_batches(token_sequences, batch_size, shuffle=True):\n","    sequence_indices = list(range(len(token_sequences)))\n","    if shuffle:\n","        random.shuffle(sequence_indices)\n","\n","    for batch_start in range(0, len(sequence_indices), batch_size):\n","        batch_indices = sequence_indices[batch_start:batch_start + batch_size]\n","        batch_sequences = [token_sequences[i] for i in batch_indices]\n","\n","        longest_sequence = max(len(seq) for seq in batch_sequences)\n","        input_rows = []\n","        target_rows = []\n","\n","        for sequence in batch_sequences:\n","            padded = sequence + [END_OF_TEXT_TOKEN] * (longest_sequence - len(sequence))\n","            input_rows.append(padded[:-1])\n","            target_rows.append(padded[1:])\n","\n","        input_tensor = torch.tensor(input_rows, dtype=torch.long, device=\"cuda\")\n","        target_tensor = torch.tensor(target_rows, dtype=torch.long, device=\"cuda\")\n","        target_tensor[target_tensor == END_OF_TEXT_TOKEN] = -100\n","        yield input_tensor, target_tensor\n","\n","\n","steps_per_epoch = math.ceil(len(training_token_sequences) / TRAIN.batch_size)\n","total_training_steps = min(steps_per_epoch * TRAIN.num_epochs, TRAIN.max_training_steps)\n","eval_interval_steps = max(1, total_training_steps // 10)\n","\n","print(f\"Steps/epoch: {steps_per_epoch}\")\n","print(f\"Total steps: {total_training_steps}\")\n","print(f\"Eval every:  {eval_interval_steps} steps (~10%)\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Steps/epoch: 1544\n","Total steps: 2500\n","Eval every:  250 steps (~10%)\n"]}],"id":"UpfcTKCRfwtJ"},{"cell_type":"markdown","metadata":{"id":"dsXpSp5mfwtJ"},"source":["## Balanced-COPA Evaluation"],"id":"dsXpSp5mfwtJ"},{"cell_type":"code","metadata":{"scrolled":true,"colab":{"referenced_widgets":["b071b00d30fa45afa685734229468ed3","af241b0af5c54460995e3fad7b1289c3","d949e5b6b8b54357969cfdf2e404cb57","26295880a55f464ea876ee44614262c6","6ea9c01327ea471bbaa554c8d345ec7e"]},"id":"OYe7CsihfwtJ","outputId":"8ab8fd47-30db-4ca5-8032-bf6972f1aabb"},"source":["CAUSAL_CONNECTIVES = {\"cause\": \"because\", \"effect\": \"therefore\"}\n","\n","balanced_copa_dataset = load_dataset(\"pkavumba/balanced-copa\", split=\"test\")\n","print(f\"Balanced-COPA: {len(balanced_copa_dataset)} examples\")\n","\n","\n","def compute_average_logprob_of_completion(model, prefix_token_ids, full_token_ids):\n","    input_ids = torch.tensor([full_token_ids[:-1]], dtype=torch.long, device=\"cuda\")\n","    target_ids = torch.tensor([full_token_ids[1:]], dtype=torch.long, device=\"cuda\")\n","\n","    with torch.autocast(device_type=\"cuda\", dtype=torch.bfloat16):\n","        logits = model(input_ids)\n","\n","    per_token_log_probs = F.log_softmax(logits[0], dim=-1)\n","    completion_start_position = len(prefix_token_ids) - 1\n","    num_completion_tokens = target_ids.shape[1] - completion_start_position\n","\n","    total_log_prob = sum(\n","        per_token_log_probs[t, target_ids[0, t]].item()\n","        for t in range(completion_start_position, target_ids.shape[1])\n","    )\n","    return total_log_prob / max(num_completion_tokens, 1)\n","\n","\n","def score_copa_choice(model, premise, connective, choice_text):\n","    prefix_text = f\"{premise} {connective} \"\n","    prefix_token_ids = TOKENIZER.encode(prefix_text)\n","    full_text = f\"{premise} {connective} {choice_text}\"\n","    full_token_ids = TOKENIZER.encode(full_text)\n","    return compute_average_logprob_of_completion(model, prefix_token_ids, full_token_ids)\n","\n","\n","@torch.no_grad()\n","def evaluate_balanced_copa_accuracy(model, dataset, num_examples=500):\n","    model.eval()\n","    num_correct = 0\n","\n","    for index, example in enumerate(dataset):\n","        if index >= num_examples:\n","            break\n","\n","        premise = example[\"premise\"].strip()\n","        connective = CAUSAL_CONNECTIVES[example[\"question\"]]\n","\n","        score_choice_1 = score_copa_choice(model, premise, connective, example[\"choice1\"])\n","        score_choice_2 = score_copa_choice(model, premise, connective, example[\"choice2\"])\n","\n","        predicted_label = 0 if score_choice_1 >= score_choice_2 else 1\n","        if predicted_label == example[\"label\"]:\n","            num_correct += 1\n","\n","    model.train()\n","    evaluated_count = min(num_examples, len(dataset))\n","    return num_correct / evaluated_count if evaluated_count > 0 else 0.0\n","\n","\n","print(f\"Balanced-COPA: {len(balanced_copa_dataset)} examples (random baseline: 50%)\")"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"b071b00d30fa45afa685734229468ed