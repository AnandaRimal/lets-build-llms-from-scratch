ompt(model, prompt_text, max_new_tokens=150, temperature=0.7, top_k=50):\n","    model.eval()\n","    token_ids = torch.tensor([TOKENIZER.encode(prompt_text)], dtype=torch.long, device=\"cuda\")\n","\n","    for _ in range(max_new_tokens):\n","        context_window = token_ids[:, -ARCH.max_sequence_len:]\n","        with torch.autocast(device_type=\"cuda\", dtype=torch.bfloat16):\n","            logits = model(context_window)\n","        next_token_logits = logits[:, -1, :] / temperature\n","\n","        if top_k > 0:\n","            top_values, _ = torch.topk(next_token_logits, min(top_k, next_token_logits.size(-1)))\n","            next_token_logits[next_token_logits < top_values[:, [-1]]] = float(\"-inf\")\n","\n","        sampled_token = torch.multinomial(F.softmax(next_token_logits, dim=-1), 1)\n","        token_ids = torch.cat([token_ids, sampled_token], dim=1)\n","        if sampled_token.item() == END_OF_TEXT_TOKEN:\n","            break\n","\n","    model.train()\n","    return TOKENIZER.decode(token_ids[0].tolist())"],"execution_count":null,"outputs":[],"id":"tuFkn-KRfwtJ"},{"cell_type":"code","metadata":{"scrolled":true,"id":"TasYH9b_fwtJ","outputId":"eed4a944-f226-488d-b1e1-51415c6cacfc"},"source":["for demo_prompt in SAMPLE_INSTRUCTION_PROMPTS:\n","    print(f\"\\n{'='*60}\")\n","    print(generate_text_from_prompt(model, demo_prompt, max_new_tokens=200))"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","============================================================\n","### Instruction:\n","Explain what a neural network is in simple terms.\n","\n","### Response:\n","What is the difference between a neural network and a neural network?\n","What is the difference between a neural network and a neural network?\n","What is the difference between a neural network and a neural network?\n","What is the difference between a neural network and a neural network?\n","What are the differences between neural networks and neural