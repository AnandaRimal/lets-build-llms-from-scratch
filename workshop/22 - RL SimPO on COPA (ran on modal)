{"cells":[{"cell_type":"markdown","metadata":{"id":"hNIAjdhrLUoD"},"source":["# RLVR SimPo on Balanced-COPA\n","Fine-tunes the instruct-tuned GPT-2 workshop model using **SimPo** (Simple Preference Optimization) with verifiable rewards from the COPA task itself.\n","\n","Each COPA example naturally produces a preference pair:\n","- **Chosen** = `premise because/therefore correct_choice`\n","- **Rejected** = `premise because/therefore wrong_choice`\n","\n","SimPo is reference-free — it replaces DPO's KL term with length-normalized log-probabilities and a target reward margin."],"id":"hNIAjdhrLUoD"},{"cell_type":"code","metadata":{"scrolled":true,"id":"Sab1umM6LUoE","outputId":"7a3ce4b1-3747-4e10-d5c4-8b0aa4e2584d"},"source":["%uv pip install -q torchao torchtune tiktoken datasets tabulate matplotlib"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Note: you may need to restart the kernel to use updated packages.\n"]}],"id":"Sab1umM6LUoE"},{"cell_type":"code","metadata":{"scrolled":true,"id":"hEf_R4cKLUoE","outputId":"32b730b0-e349-404d-cd7b-4eb21c95de03"},"source":["import os\n","import random\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","import tiktoken\n","import matplotlib.pyplot as plt\n","from dataclasses import dataclass\n","from datasets import load_dataset\n","from tabulate import tabulate\n","from torchtune.modules import (\n","    RMSNorm,\n","    RotaryPositionalEmbeddings,\n","    MultiHeadAttention,\n","    TransformerSelfAttentionLayer,\n","    TransformerDecoder,\n","    TiedLinear,\n",")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["Skipping import of cpp extensions due to incompatible torch version. Please upgrade to torch >= 2.11.0 (found 2.8.0+cu129).\n","/usr/local/lib/python3.12/site-packages/torchao/quantization/quant_api.py:1731: SyntaxWarning: invalid escape sequence '\\.'\n","  \"\"\"Configuration class for applying different quantization configs to modules or parameters based on their fully qualified names (FQNs).\n"]}],"id":"hEf_R4cKLUoE"},{"cell_type":"markdown","metadata":{"id":"JmKT5hLXLUoF"},"source":["## Configuration"],"id":"JmKT5hLXLUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"2p7af0X6LUoF"},"source":["CHECKPOINT_DIR = \"/mnt/gpt2-workshop/checkpoints\"\n","INSTRUCT_CHECKPOINT_PATH = f\"{CHECKPOINT_DIR}/workshop-v1-instruct-tuned.pth\"\n","RL_OUTPUT_PATH = f\"{CHECKPOINT_DIR}/workshop-v1-rl.pth\"\n","TOKENIZER = tiktoken.get_encoding(\"gpt2\")\n","QUESTION_TO_CONNECTIVE = {\"cause\": \"because\", \"effect\": \"therefore\"}"],"execution_count":null,"outputs":[],"id":"2p7af0X6LUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"riSSgs37LUoF"},"source":["@dataclass\n","class SimPoConfig:\n","    beta: float = 2.0\n","    gamma: float = 0.5\n","    learning_rate: float = 1e-6\n","    number_of_epochs: int = 4\n","    eval_every_n_steps: int = 100\n","    max_grad_norm: float = 1.0"],"execution_count":null,"outputs":[],"id":"riSSgs37LUoF"},{"cell_type":"markdown","metadata":{"id":"IeT0JALWLUoF"},"source":["## Model Architecture"],"id":"IeT0JALWLUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"4xsdo01ALUoF"},"source":["class ReluSquaredMLP(nn.Module):\n","    def __init__(self, embedding_dim, hidden_dim):\n","        super().__init__()\n","        self.fc_in = nn.Linear(embedding_dim, hidden_dim, bias=False)\n","        self.fc_out = nn.Linear(hidden_dim, embedding_dim, bias=False)\n","\n","    def forward(self, x):\n","        return self.fc_out(F.relu(self.fc_in(x)).square())\n","\n","\n","@dataclass\n","class ModelConfig:\n","    number_of_layers:    int = 12\n","    number_of_heads:     int = 12\n","    embedding_dim:       int = 768\n","    vocab_size:          int = 50304\n","    max_sequence_length: int = 1024\n","    feedforward_dim:     int = 3072\n","    rope_theta:          float = 10000.0\n","\n","\n","def build_gpt2_model(config=ModelConfig()):\n","    head_dim = config.embedding_dim // config.number_of_heads\n","\n","    rope = RotaryPositionalEmbeddings(\n","        dim=head_dim, max_seq_len=config.max_sequence_length, base=config.rope_theta,\n","    )\n","    attention = MultiHeadAttention(\n","        embed_dim=config.embedding_dim, num_heads=config.number_of_heads,\n","        num_kv_heads=config.number_of_heads, head_dim=head_dim,\n","        q_proj=nn.Linear(config.embedding_dim, config.embedding_dim, bias=False),\n","        k_proj=nn.Linear(config.embedding_dim, config.embedding_dim, bias=False),\n","        v_proj=nn.Linear(config.embedding_dim, config.embedding_dim, bias=False),\n","        output_proj=nn.Linear(config.embedding_dim, config.embedding_dim, bias=False),\n","        pos_embeddings=rope, max_seq_len=config.max_sequence_length, attn_dropout=0.0,\n","    )\n","    feedforward = ReluSquaredMLP(config.embedding_dim, config.feedforward_dim)\n","    transformer_layer = TransformerSelfAttentionLayer(\n","        attn=attention, mlp=feedforward,\n","        sa_norm=RMSNorm(config.embedding_dim), mlp_norm=RMSNorm(config.embedding_dim),\n","    )\n","    token_embeddings = nn.Embedding(config.vocab_size, config.embedding_dim)\n","\n","    return TransformerDecoder(\n","        tok_embeddings=token_embeddings, layers=transformer_layer,\n","        num_layers=config.number_of_layers, max_seq_len=config.max_sequence_length,\n","        num_heads=config.number_of_heads, head_dim=head_dim,\n","        norm=RMSNorm(config.embedding_dim), output=TiedLinear(token_embeddings),\n","    )\n","\n","\n","def load_checkpoint_into_model(checkpoint_path):\n","    model = build_gpt2_model().cuda()\n","    checkpoint = torch.load(checkpoint_path, map_location=\"cuda\", weights_only=False)\n","    state_dict = checkpoint[\"model\"] if \"model\" in checkpoint else checkpoint\n","    model.load_state_dict(state_dict)\n","    total_params = sum(p.numel() for p in model.parameters())\n","    print(f\"Loaded {checkpoint_path.split('/')[-1]} — {total_params:,} params\")\n","    return model"],"execution_count":null,"outputs":[],"id":"4xsdo01ALUoF"},{"cell_type":"markdown","metadata":{"id":"ewz3UavhLUoF"},"source":["## SimPo: Simple Preference Optimization\n","\n","**Loss** = `-log(σ(β · (r_chosen - r_rejected) - γ))`\n","\n","where the implicit reward for a completion is its **length-normalized average log-probability**:\n","\n","`r(completion) = (1 / |completion_tokens|) · Σ log P(token_i | prefix)`\n","\n","No reference model needed. β controls sensitivity to the reward gap, γ sets the target margin between chosen and rejected."],"id":"ewz3UavhLUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"270t12JuLUoF"},"source":["def tokenize_copa_as_preference_pair(example):\n","    premise = example[\"premise\"].strip()\n","    connective = QUESTION_TO_CONNECTIVE[example[\"question\"]]\n","    label = example[\"label\"]\n","\n","    choices = [example[\"choice1\"], example[\"choice2\"]]\n","    chosen_text = f\"{premise} {connective} {choices[label]}\"\n","    rejected_text = f\"{premise} {connective} {choices[1 - label]}\"\n","\n","    prefix_text = f\"{premise} {connective} \"\n","    prefix_length = len(TOKENIZER.encode(prefix_text))\n","\n","    return {\n","        \"chosen_tokens\": TOKENIZER.encode(chosen_text),\n","        \"rejected_tokens\": TOKENIZER.encode(rejected_text),\n","        \"prefix_length\": prefix_length,\n","    }\n","\n","\n","def length_normalized_logprob(logits, token_ids, completion_start_index):\n","    log_probs = F.log_softmax(logits[0], dim=-1)\n","\n","    completion_token_logprobs = [\n","        log_probs[t, token_ids[0, t]]\n","        for t in range(completion_start_index, token_ids.shape[1])\n","    ]\n","    completion_length = len(completion_token_logprobs)\n","    if completion_length == 0:\n","        return torch.tensor(0.0, device=logits.device)\n","\n","    return torch.stack(completion_token_logprobs).sum() / completion_length\n","\n","\n","def simpo_loss(model, chosen_tokens, rejected_tokens, prefix_length, beta, gamma):\n","    chosen_input = torch.tensor([chosen_tokens[:-1]], dtype=torch.long, device=\"cuda\")\n","    chosen_target = torch.tensor([chosen_tokens[1:]], dtype=torch.long, device=\"cuda\")\n","    rejected_input = torch.tensor([rejected_tokens[:-1]], dtype=torch.long, device=\"cuda\")\n","    rejected_target = torch.tensor([rejected_tokens[1:]], dtype=torch.long, device=\"cuda\")\n","\n","    completion_start = prefix_length - 1\n","\n","    with torch.autocast(device_type=\"cuda\", dtype=torch.bfloat16):\n","        chosen_logits = model(chosen_input)\n","        rejected_logits = model(rejected_input)\n","\n","    chosen_reward = length_normalized_logprob(chosen_logits, chosen_target, completion_start)\n","    rejected_reward = length_normalized_logprob(rejected_logits, rejected_target, completion_start)\n","\n","    reward_margin = beta * (chosen_reward - rejected_reward) - gamma\n","    loss = -F.logsigmoid(reward_margin)\n","\n","    chosen_is_preferred = (chosen_reward > rejected_reward).item()\n","    return loss, chosen_reward.item(), rejected_reward.item(), chosen_is_preferred"],"execution_count":null,"outputs":[],"id":"270t12JuLUoF"},{"cell_type":"markdown","metadata":{"id":"LE1stmjKLUoF"},"source":["## Evaluation"],"id":"LE1stmjKLUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"1SLOpgw4LUoF"},"source":["@torch.no_grad()\n","def evaluate_copa(model, dataset):\n","    model.eval()\n","    correct = 0\n","\n","    for example in dataset:\n","        premise = example[\"premise\"].strip()\n","        connective = QUESTION_TO_CONNECTIVE[example[\"question\"]]\n","        choices = [example[\"choice1\"], example[\"choice2\"]]\n","\n","        prefix_text = f\"{premise} {connective} \"\n","        prefix_tokens = TOKENIZER.encode(prefix_text)\n","        prefix_length = len(prefix_tokens)\n","\n","        scores = []\n","        for choice in choices:\n","            full_tokens = TOKENIZER.encode(f\"{premise} {connective} {choice}\")\n","            input_ids = torch.tensor([full_tokens[:-1]], dtype=torch.long, device=\"cuda\")\n","            target_ids = torch.tensor([full_tokens[1:]], dtype=torch.long, device=\"cuda\")\n","\n","            with torch.autocast(device_type=\"cuda\", dtype=torch.bfloat16):\n","                logits = model(input_ids)\n","\n","            score = length_normalized_logprob(logits, target_ids, prefix_length - 1)\n","            scores.append(score.item())\n","\n","        predicted_label = 0 if scores[0] >= scores[1] else 1\n","        if predicted_label == example[\"label\"]:\n","            correct += 1\n","\n","    model.train()\n","    return correct / len(dataset)"],"execution_count":null,"outputs":[],"id":"1SLOpgw4LUoF"},{"cell_type":"markdown","metadata":{"id":"gDc2zE9ELUoF"},"source":["## Load Data"],"id":"gDc2zE9ELUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"jKaPoAg1LUoF","outputId":"00c71080-980b-46bc-bfc0-3f082215f013","colab":{"referenced_widgets":["99ab69ddbf2e4dff8b7d4637d38528f8","789d11a9cd1c4a47ba7c5b576ad784f4","06ee517ec0c24e53b9741f18f1a34e76","135fcf08cfbd4cd98a3275139835d3a8","f7e9f5ea757c44a7839240e8205fe746"]}},"source":["copa_train = load_dataset(\"pkavumba/balanced-copa\", split=\"train\")\n","copa_test = load_dataset(\"pkavumba/balanced-copa\", split=\"test\")\n","print(f\"Train: {len(copa_train)} examples, Test: {len(copa_test)} examples\")\n","\n","training_pairs = [tokenize_copa_as_preference_pair(ex) for ex in copa_train]\n","print(f\"Tokenized {len(training_pairs)} preference pairs\")"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"99ab69ddbf2e4dff8b7d4637d38528f8","version_minor":0,"version_major":2},"text/plain":"README.md: 0.00B [00:00, ?B/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"789d11a9cd1c4a47ba7c5b576ad784f4","version_minor":0,"version_major":2},"text/plain":"train.csv: 0.00B [00:00, ?B/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"06ee517ec0c24e53b9741f18f1a34e76","version_minor":0,"version_major":2},"text/plain":"test.csv: 0.00B [00:00, ?B/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"135fcf08cfbd4cd98a3275139835d3a8","version_minor":0,"version_major":2},"text/plain":"Generating train split:   0%|          | 0/1000 [00:00<?, ? examples/s]"},"metadata":{}},{"output_type":"display_data","data":{"application/vnd.jupyter.widget-view+json":{"model_id":"f7e9f5ea757c44a7839240e8205fe746","version_minor":0,"version_major":2},"text/plain":"Generating test split:   0%|          | 0/500 [00:00<?, ? examples/s]"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Train: 1000 examples, Test: 500 examples\n","Tokenized 1000 preference pairs\n"]}],"id":"jKaPoAg1LUoF"},{"cell_type":"markdown","metadata":{"id":"yDJSvke_LUoF"},"source":["## Training Loop"],"id":"yDJSvke_LUoF"},{"cell_type":"code","metadata":{"scrolled":true,"id":"v2rVeV22LUoF","outputId":"baeda479-453c-41dc-89ad-171240ac8a97"},"source":["simpo_config = SimPoConfig()\n","\n","model = load_checkpoint_into_model(INSTRUCT_CHECKPOINT_PATH)\n","model.train()\n","\n","optimizer = torch.optim.AdamW(model.parameters(), lr=simpo_config.learning_rate)\n","\n","step = 0\n","training_log = []\n","eval_log = []\n","\n","print(f\"Training {simpo_config.number_of_epochs} epochs × {len(training_pairs)} examples = {simpo_config.number_of_epochs * len(training_pairs)} steps\")\n","print(f\"SimPo β={simpo_config.beta}, γ={simpo_config.gamma}, lr={simpo_config.learning_rate}\")\n","print(\"-\" * 70)\n","\n","for epoch in range(simpo_config.number_of_epochs):\n","    shuffled_pairs = training_pairs.copy()\n","    random.shuffle(shuffled_pairs)\n","\n","    for pair in shuffled_pairs:\n","        optimizer.zero_grad()\n","\n","        loss, chosen_reward, rejected_reward, chosen_preferred = simpo_loss(\n","            model,\n","            pair[\"chosen_tokens\"],\n","            pair[\"rejected_tokens\"],\n","            pair[\"prefix_length\"],\n","            simpo_config.beta,\n","            simpo_config.gamma,\n","        )\n","\n","        loss.backward()\n","        torch.nn.utils.clip_grad_norm_(model.parameters(), simpo_config.max_grad_norm)\n","        optimizer.step()\n","\n","        step += 1\n","        training_log.append({\n","            \"step\": step,\n","            \"loss\": loss.item(),\n","            \"chosen_reward\": chosen_reward,\n","            \"rejected_reward\": rejected_reward,\n","            \"reward_margin\": chosen_reward - rejected_reward,\n","            \"implicit_accuracy\": float(chosen_preferred),\n","        })\n","\n","        if step % 50 == 0:\n","            recent_losses = [e[\"loss\"] for e in training_log[-50:]]\n","            recent_accuracy = [e[\"implicit_accuracy\"] for e in training_log[-50:]]\n","            print(\n","                f\"step {step:>5d} | \"\n","                f\"loss {sum(recent_losses)/len(recent_losses):.4f} | \"\n","                f\"pair_acc {sum(recent_accuracy)/len(recent_accuracy):.1%}\"\n","            )\n","\n","        if step % simpo_config.eval_every_n_steps == 0:\n","            accuracy = evaluate_copa(model, copa_test)\n","            eval_log.append({\"step\": step, \"accuracy\": accuracy})\n","            print(f\"  >>> COPA eval @ step {step}: {accuracy*100:.1f}%\")\n","\n","print(f\"\\nTraining complete. Final step: {step}\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded workshop-v1-instruct-tuned.pth — 123,587,328 params\n","Training 4 epochs × 1000 examples = 4000 steps\n","SimPo β=2.0, γ=0.5, lr=1e-06\n","----------------------------------------------------------------------\n","step 