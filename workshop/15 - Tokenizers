"        self.vocab_size = len(self.unique_words)\n","\n","        # Create mappings from word to integer and vice versa\n","        self.word_to_int = {word: i for i, word in enumerate(self.unique_words)}\n","        self.int_to_word = {i: word for i, word in enumerate(self.unique_words)}\n","\n","        print(f\"Corpus length: {len(text_corpus.split())} words\")\n","        print(f\"Vocabulary size: {self.vocab_size} words\")\n","\n","    def encode(self, text_string):\n","        # Split text into words and return known token IDs (ignoring unknown words for simplicity)\n","        return [self.word_to_int[word] for word in text_string.split() if word in self.word_to_int]\n","\n","    def decode(self, token_ids):\n","        # Join decoded words back into a single string\n","        return ' '.join([self.int_to_word[tid] for tid in token_ids])\n","\n","# Instantiate the word tokenizer\n","tokenizer_word = ByWordTokenizer(corpus)\n","print(f\"Compression ratio: {len(set(tokenizer_word.encode(corpus))) / len(corpus.split()):.2f}x\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Corpus length: 100000 words\n","Vocabulary size: 21884 words\n","Compression ratio: 0.22x\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":269},"id":"94464a9b","executionInfo":{"status":"ok","timestamp":1775251010999,"user_tz":420,"elapsed":7,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"a509d2ff-5a5f-4617-f494-862db66d5f30"},"source":["# Test the encode/decode on a known phrase from the corpus\n","test_phrase = \"The Independent Jane For all the love,\"\n","encoded_word_tokens = tokenizer_word.encode(test_phrase)\n","decoded_words = [tokenizer_word.decode([t]) for t in encoded_word_tokens]\n","\n","# Create and display the DataFrame\n","display(pd.DataFrame({\n","    \"Token ID\": encoded_word_tokens,\n","    \"Decoded Word\": decoded_words\n","}))"],"execution_count":nul