es} merges...\")\n","        self.tokenize_n_times(num_merges)\n","        print(\"BPE training complete.\")\n","\n","    def pretokenize_create_vocab(self, corpus_text):\n","        for word in corpus_text.split():\n","            spaced_characters = ' '.join(list(word)) + ' </w>'\n","            self.vocabulary[spaced_characters] += 1\n","\n","    def tokenize_n_times(self, num_merges):\n","        for current_step in range(num_merges):\n","            could_merge = self.tokenize_one_round(current_step)\n","            if not could_merge:\n","                print(f\"Stopping early at step {current_step}: No more pairs to merge.\")\n","                break\n","\n","    def tokenize_one_round(self, step_num):\n","        pair_frequencies = self.calculate_pair_frequencies(self.vocabulary)\n","        if not pair_frequencies:\n","            return False\n","\n","        most_frequent_pair = max(pair_frequencies, key=pair_frequencies.get)\n","\n","        print(f\"Step {step_num}: Merging pair {most_frequent_pair} with frequency {pair_frequencies[most_frequent_pair]}\")\n","\n","        self.vocabulary = self.merge_vocabulary_pair(most_frequent_pair, self.vocabulary)\n","        return True\n","\n","    def calculate_pair_frequencies(self, current_vocabulary):\n","        pair_frequencies = defaultdict(int)\n","        for word_symbols, frequency in current_vocabulary.items():\n","            symbols_list = word_symbols.split()\n","            for index in range(len(symbols_list) - 1):\n","                pair_frequencies[symbols_list[index], symbols_list[index+1]] += frequency\n","        return pair_frequencies\n","\n","    def merge_vocabulary_pair(self, pair_to_merge, current_vocabulary):\n","        updated_vocabulary = {}\n","        bigram_string = re.escape(' '.join(pair_to_merge))\n","        exact_match_regex = re.compile(r'(?<!\\S)' + bigram_string + r'(?!\\S)')\n","\n","        for word_symbols, frequency in current_vocabulary.items():\n","            me