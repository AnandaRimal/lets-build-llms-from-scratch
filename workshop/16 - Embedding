Apply Absolute positional sinusoidal embeddings"],"metadata":{"id":"f2ToA2sYlIh5"}},{"cell_type":"code","source":["if embeddings.dim() == 1:\n","    embeddings = embeddings.unsqueeze(0)\n","\n","seq_len, dim = embeddings.shape\n","pos = torch.arange(seq_len).unsqueeze(1)\n","div = torch.exp(torch.arange(0, dim, 2) * (-math.log(10000.0) / dim))\n","\n","positional_embeddings = torch.zeros(seq_len, dim)\n","positional_embeddings[:, 0::2] = torch.sin(pos * div)\n","positional_embeddings[:, 1::2] = torch.cos(pos * div)\n","\n","embeddings_with_pos = embeddings + positional_embeddings"],"metadata":{"id":"l77uCP9g3sdm"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# 6) Visualize learned positional vs. sinusoidal"],"metadata":{"id":"7b8wtKZ-pH-_"}},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":790},"id":"be6dfb22","executionInfo":{"status":"ok","timestamp":1775274709036,"user_tz":420,"elapsed":808,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"fa340a23-5310-4f04-a0f0-9873359722b5"},"source":["# Get the positional embeddings as a numpy array\n","pos_embs = positional_embeddings.detach().numpy()\n","\n","# Create figure and axis with publication-quality settings\n","fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 10), dpi=150)\n","fig.patch.set_facecolor('#1E293B')\n","\n","# Set styling for all text and lines to match previous plot\n","plt.rcParams['text.color'] = '#F1F5F9'\n","plt.rcParams['axes.labelcolor'] = '#F1F5F9'\n","plt.rcParams['xtick.color'] = '#F1F5F9'\n","plt.rcParams['ytick.color'] = '#F1F5F9'\n","\n","for ax in [ax1, ax2]:\n","    ax.set_facecolor('#1E293B')\n","    ax.spines['top'].set_visible(False)\n","    ax.spines['right'].set_visible(False)\n","    ax.spines['bottom'].set_color('#F1F5F9')\n","    ax.spines['left'].set_color('#F1F5F9')\n","\n","# --- Subplot 1: Heatmap ---\n","# We'll show the first 100 positions to see the pattern clearly\n","im = ax1.imshow(pos_embs[:100, :], cmap='magma', aspect='auto')\n","ax1.set_title(\"Heatmap of Positional Embeddings (First 100 Positions)\", fontsize=15, weight='bold', pad=15)\n","ax1.set_xlabel(\"Embedding Dimension (0-767)\", fontsize=12, labelpad=10)\n","ax1.set_ylabel(\"Position (0-99)\", fontsize=12, labelpad=10)\n","\n","# Colorbar styling\n","cbar = fig.colorbar(im, ax=ax1)\n","cbar.ax.yaxis.set_tick_params(color='#F1F5F9')\n","plt.setp(plt.getp(cbar.ax.axes, 'yticklabels'), color='#F1F5F9')\n","\n","# --- Subplot 2: Line plots ---\n","# Let's pick a few dimensions to see their wave patterns\n","dims_to_plot = [10, 50, 100, 500]\n","colors = ['#8C7BEF', '#34D399', '#F472B6', '#FBBF24']\n","\n","for dim, color in zip(dims_to_plot, colors):\n","    ax2.plot(pos_embs[:100, dim], label=f'Dimension {dim}', color=color, linewidth=2.5, alpha=0.9)\n","\n","ax2.set_title(\"Wave Patterns in Specific Dimensions (First 100 Positions)\", fontsize=15, weight='bold', pad=15)\n","ax2.set_xlabel(\"Position (0-99)\", fontsize=12, labelpad=10)\n","ax2.set_ylabel(\"Embedding Value\", fontsize=12, labelpad=10)\n","ax2.legend(facecolor='#1E293B', edgecolor='#5D6674', labelcolor='#F1F5F9', loc='upper right')\n","ax2.grid(axis='both', alpha=0.2, color='#5D6674', linestyle='--')\n","\n","plt.tight_layout()\n","plt.show()"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x1500 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":790},"id":"61f8257e","executionInfo":{"status":"ok","timestamp":1775275144151,"user_tz":420,"elapsed":1792,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"3d8b265b-f2ba-44b7-82c0-a48e7b963570"},"source":["def get_sinusoidal_embeddings(max_seq_len, embed_dim):\n","    # Create a matrix of shape (max_seq_len, embed_dim)\n","    embeddings = np.zeros((max_seq_len, embed_dim))\n","\n","    # Get positions (0 to max_seq_len-1) as a column vector\n","    positions = np.arange(max_seq_len)[:, np.newaxis]\n","\n","    # Calculate the division term for the frequencies\n","    div_term = np.exp(np.arange(0, embed_dim, 2) * -(np.log(10000.0) / embed_dim))\n","\n","    # Apply sine to even indices, cosine to odd indices\n","    embeddings[:, 0::2] = np.sin(positions * div_term)\n","    embeddings[:, 1::2] = np.cos(positions * div_term)\n","\n","    return embeddings\n","\n","# Generate sinusoidal embeddings for 100 positions and 768 dimensions\n","sin_embs = get_sinusoidal_embeddings(100, 768)\n","\n","# --- Plotting the Beautiful Waves ---\n","fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 10), dpi=150)\n","fig.patch.set_facecolor('#1E293B')\n","\n","for ax in [ax1, ax2]:\n","    ax.set_facecolor('#1E293B')\n","    ax.spines['top'].set_visible(False)\n","    ax.spines['right'].set_visible(False)\n","    ax.spines['bottom'].set_color('#F1F5F9')\n","    ax.spines['left'].set_color('#F1F5F9')\n","    ax.tick_params(colors='#F1F5F9')\n","\n","# Subplot 1: Heatmap\n","im = ax1.imshow(sin_embs, cmap='magma', aspect='auto')\n","ax1.set_title(\"Heatmap of Fixed Sinusoidal Positional Embeddings\", fontsize=15, weight='bold', pad=15, color='#F1F5F9')\n","ax1.set_xlabel(\"Embedding Dimension (0-767)\", fontsize=12, labelpad=10, color='#F1F5F9')\n","ax1.set_ylabel(\"Position (0-99)\", fontsize=12, labelpad=10, color='#F1F5F9')\n","\n","cbar = fig.colorbar(im, ax=ax1)\n","cbar.ax.yaxis.set_tick_params(color='#F1F5F9')\n","plt.setp(plt.getp(cbar.ax.axes, 'yticklabels'), color='#F1F5F9')\n","\n","# Subplot 2: Line plots of specific dimensions\n","dims_to_plot = [10, 50, 100, 500]\n","colors = ['#8C7BEF', '#34D399', '#F472B6', '#FBBF24']\n","\n","for dim, color in zip(dims_to_plot, colors):\n","    ax2.plot(sin_embs[:, dim], label=f'Dimension {dim}', color=color, linewidth=2.5, alpha=0.9)\n","\n","ax2.set_title(\"Beautiful Smooth Waves in Specific Dimensions\", fontsize=15, weight='bold', pad=15, color='#F1F5F9')\n","ax2.set_xlabel(\"Position (0-99)\", fontsize=12, labelpad=10, color='#F1F5F9')\n","ax2.set_ylabel(\"Embedding Value\", fontsize=12, labelpad=10, color='#F1F5F9')\n","ax2.legend(facecolor='#1E293B', edgecolor='#5D6674', labelcolor='#F1F5F9', loc='upper right')\n","ax2.grid(axis='both', alpha=0.2, color='#5D6674', linestyle='--')\n","\n","plt.tight_layout()\n","plt.show()"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x1500 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]}]}