d":"17586265333179008491"}}},"execution_count":20,"outputs":[]},{"cell_type":"code","metadata":{"id":"27ebb6db","executionInfo":{"status":"ok","timestamp":1777746802950,"user_tz":420,"elapsed":1778,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"colab":{"base_uri":"https://localhost:8080/","height":707},"outputId":"551daf11-785c-43dd-e7f2-a50ce04313ce"},"source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from matplotlib import cm\n","\n","# Create grid of weights and biases\n","weights = np.linspace(-2.0, 3.0, 100)\n","biases = np.linspace(-2.0, 2.0, 100)\n","W, B = np.meshgrid(weights, biases)\n","\n","input = 1.0\n","y_expected = 0.1\n","\n","# We will calculate MSE loss for each combination\n","Loss = np.zeros_like(W)\n","\n","# Use the existing perceptron class and its update functions\n","for i in range(W.shape[0]):\n","    for j in range(W.shape[1]):\n","        # Update the perceptron with current grid values\n","        perceptron.set_weight(W[i, j])\n","        perceptron.set_bias(B[i, j])\n","\n","        # Predict\n","        y_predicted = perceptron(input)\n","\n","        # Calculate MSE loss\n","        Loss[i, j] = (y_predicted - y_expected)**2\n","\n","visualize_loss()"],"execution_count":21,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x700 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# 5) Exercise: visualize loss\n"],"metadata":{"id":"rsoPnIg_1slO"}},{"cell_type":"code","source":["# Visualize the loss for different input and  y_expected values."],"metadata":{"id":"W9v8kEZy12qi","executionInfo":{"status":"ok","timestamp":1777746802953,"user_tz":420,"elapsed":1,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}}},"execution_count":22,"outputs":[]},{"cell_type":"markdown","source":[" # 6) cross Entropy - MLP 1->10 for first digit detection"],"metadata":{"id":"ljr3u3vupz87"}},{"cell_type":"code","source":["#@title visualization helpers\n","def visualize_logits(logits, target_class=None):\n","    logits_np = logits.detach().numpy().flatten()\n","    digits = np.arange(10)\n","    predicted_idx = np.argmax(logits_np)\n","\n","    plt.figure(figsize=(10, 4))\n","    colors = ['skyblue' if i != predicted_idx else 'orange' for i in range(10)]\n","\n","    bars = plt.bar(digits, logits_np, color=colors)\n","\n","    plt.xticks(digits)\n","    plt.xlabel('Digit Class')\n","    plt.ylabel('Logit Value')\n","    plt.title(f'Logit Visualization (Predicted Digit: {predicted_idx})')\n","\n","    if target_class is not None:\n","        target_val = target_class.item()\n","        plt.axvline(x=target_val, color='red', linestyle='--', alpha=0.6, label=f'Target: {target_val}')\n","        plt.legend()\n","\n","    plt.show()\n","\n","def visualize_loss_surface(W, B, Loss):\n","  # Create a pretty 3D surface plot\n","  fig = plt.figure(figsize=(10, 7))\n","  ax = fig.add_subplot(111, projection='3d')\n","\n","  # Plot the surface\n","  surf = ax.plot_surface(W, B, Loss, cmap=cm.viridis, edgecolor='none', alpha=0.9)\n","\n","  # Add labels and title\n","  ax.set_title(f'10-Class Cross Entropy Loss Landscape (input={input}, target_class={target_class.item()})')\n","  ax.set_xlabel('Weight')\n","  ax.set_ylabel('Bias')\n","  ax.set_zlabel('CE Loss')\n","\n","  # Add a color bar which maps values to colors\n","  fig.colorbar(surf, shrink=0.5, aspect=5, label='Loss')\n","\n","  plt.tight_layout()\n","  plt.show()"],"metadata":{"id":"CM4Fabj9nEtO","executionInfo":{"status":"ok","timestamp":1777746802955,"user_tz":420,"elapsed":1,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}}},"execution_count":23,"outputs":[]},{"cell_type":"code","source":["class DigitMLP(nn.Module):\n","    def __init__(self, weight: float, bias: float):\n","        super().__init__()\n","        self.weight = float(weight)\n","        self.bias = float(bias)\n","\n","    def forward(self, x: float):\n","        neuron_value = x * self.weight + self.bias\n","        # 10 outputs (logits).\n","        # highest logit is the predicted first digit\n","        logits = [1-abs(neuron_value - float(i)) for i in range(10)]\n","        return torch.tensor([logits])\n","\n","    def set_weight(self, new_weight: float):\n","        self.weight = float(new_weight)\n","\n","    def set_bias(self, new_bias: float):\n","        self.bias = float(new_bias)"],"metadata":{"id":"Bj1WhwYrmWyp","executionInfo":{"status":"ok","timestamp":1777746802956,"user_tz":420,"elapsed":1,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}}},"execution_count":24,"outputs":[]},{"cell_type":"code","source":["mlp = DigitMLP(weight=1.0, bias=0.0)\n","\n","input = 1.3\n","target_class = torch.tensor([1]) # Target is the number 1 at position 1\n","\n","logits = mlp(input)\n","print(logits)\n","\n","visualize_logits(logits, target_class)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":437},"id":"r5GhqU6Gmc90","executionInfo":{"status":"ok","timestamp":1777746803036,"user_tz":420,"elapsed":79,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"271c18b6-964b-4d26-b98a-9ec20c3e10f0"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stdout","text":["tensor([[-0.3000,  0.7000,  0.3000, -0.7000, -1.7000, -2.7000, -3.7000, -4.7000,\n","         -5.7000, -6.7000]])\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# calculate the top logit position\n","top_logit_position = torch.argmax(logits)\n","print(top_logit_position)\n","\n","# calculate cross entropy loss\n","loss = F.cross_entropy(logits, target_class)\n","print(loss)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GBia65WVorGD","executionInfo":{"status":"ok","timestamp":1777746803040,"user_tz":420,"elapsed":3,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"5955d345-edc3-44c2-9477-fdf2d4dc1937"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["tensor(1)\n","tensor(0.8870)\n"]}]},{"cell_type":"code","source":["# Walk the W+B space and visualize\n","weights = np.linspace(-2.0, 3.0, 100)\n","biases = np.linspace(-2.0, 2.0, 100)\n","W, B = np.meshgrid(weights, biases)\n","\n","observed_loss_values = np.zeros_like(W)\n","\n","# Use the MLP and its update functions\n","for i in range(W.shape[0]):\n","    for j in range(W.shape[1]):\n","        # Update MLP with current grid values\n","        mlp.set_weight(W[i, j])\n","        mlp.set_bias(B[i, j])\n","\n","        # Predict\n","        out_logits = mlp(input)\n","\n","        # Calculate Cross-Entropy loss\n","        observed_loss_values[i, j] = F.cross_entropy(out_logits, target_class).item()\n","\n","visualize_loss_surface(W, B, observed_loss_values)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":707},"id":"LjP03pk9iNDI","executionInfo":{"status":"ok","timestamp":1777746804757,"user_tz":420,"elapsed":1710,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"outputId":"6fb7e03e-a8c5-4c8b-ba55-364a596d8f00"},"execution_count":27,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x700 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# 7) Exercise: visualize the loss landscape for different value"],"metadata":{"id":"e6E2g0Mk2OpG"}},{"cell_type":"code","source":["#@title Answer\n","#  for input=9, target_class=9\n","input = 9\n","target_class = torch.tensor([9]) # Target is the number 1 at position 1\n","\n","logits = mlp(input)\n","print(logits)\n","\n","visualize_logits(logits, target_class)"],"metadata":{"id":"M3Jusawu2MpP","executionInfo":{"status":"ok","timestamp":1777746804775,"user_tz":420,"elapsed":16,"user":{"displayName":"Justin Angel","userId":"17586265333179008491"}},"colab":{"base_