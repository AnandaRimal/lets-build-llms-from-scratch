gpu)\n","\n","# --- Benchmark all 6 ---\n","print(\"Benchmarking (this takes a minute or two)...\\n\")\n","\n","timings = {}\n","# timings['1. Python']         = benchmark('Python',         lambda: perceptron_python(input_val, weight_val, bias_val))\n","timings['2. nn.Module']      = benchmark('nn.Module',      lambda: model_manual(input_gpu),                          use_cuda_events=True)\n","timings['3. Compiled']       = benchmark('Compiled',       lambda: model_compiled(input_gpu),                        use_cuda_events=True)\n","timings['4. nn.Linear']      = benchmark('nn.Linear',      lambda: model_linear(input_linear),                       use_cuda_events=True)\n","timings['5. CUDA C++']       = benchmark('CUDA C++',       lambda: cuda_ext.perceptron_cuda(input_gpu, w_gpu, b_gpu),use_cuda_events=True)\n","timings['6. Triton']         = benchmark('Triton',         lambda: perceptron_triton(input_gpu, w_gpu, b_gpu),       use_cuda_events=True)\n","\n","# --- Table ---\n","print(f\"{'Approach':<20} {'Median (µs)':>12} {'vs Python':>10}\")\n","print(\"-\" * 44)\n","baseline = timings['1. Python']\n","for name, t in timings.items():\n","    ratio = f\"{t / baseline:.1f}x\"\n","    print(f\"{name:<20} {t:>12.2f} {ratio:>10}\")\n","\n","# --- Chart ---\n","names = list(timings.keys())\n","times = list(timings.values())\n","colors = ['#2ecc71', '#3498db', '#9b59b6', '#e67e22', '#e74c3c', '#1abc9c']\n","\n","fig, ax = plt.subplots(figsize=(10, 4))\n","bars = ax.barh(names, times, color=colors)\n","ax.set_xscale('log')\n","ax.set_xlabel('Median Latency (µs) — log scale')\n","ax.set_title(f'Single Perceptron: y = w·x + b  ({GPU_NAME})')\n","for bar, t in zip(bars, times):\n","    ax.text(t * 1.4, bar.get_y() + bar.get_height()/2,\n","            f'{t:.1f} µs', va='center', fontsize=10, fontweight='bold')\n","ax.invert_yaxis()\n","plt.tight_layout()\n","plt.show()"],"metadata":{"id":"6utKccPcn7uU","executionInfo":{"status":"error","timestamp":1773795313846,"user_tz":42